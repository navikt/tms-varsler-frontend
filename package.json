{
  "name": "tms-varsler-frontend",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "PUBLIC_APP_ENVIRONMENT=local astro dev",
    "start": "PUBLIC_APP_ENVIRONMENT=${PUBLIC_APP_ENVIRONMENT:-local} astro dev",
    "build": "PUBLIC_APP_ENVIRONMENT=${PUBLIC_APP_ENVIRONMENT:-local} astro check && PUBLIC_APP_ENVIRONMENT=${PUBLIC_APP_ENVIRONMENT:-local} astro build",
    "preview": "PUBLIC_APP_ENVIRONMENT=${PUBLIC_APP_ENVIRONMENT:-local} astro preview",
    "astro": "PUBLIC_APP_ENVIRONMENT=${PUBLIC_APP_ENVIRONMENT:-local} astro",
    "mock": "tsx --watch ./mock/server.ts",
    "ts-check": "tsc --strict",
    "prettier": "prettier --write './src/**/*.{ts,tsx,astro}'",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "0.9.4",
    "@astrojs/node": "9.3.0",
    "@astrojs/react": "4.3.0",
    "@nanostores/react": "1.0.0",
    "@navikt/aksel-icons": "8.10.4",
    "@navikt/ds-react": "8.10.4",
    "@navikt/nav-dekoratoren-moduler": "3.4.0",
    "@navikt/oasis": "3.8.0",
    "@opentelemetry/sdk-node": "0.202.0",
    "astro": "5.11.2",
    "dayjs": "1.11.13",
    "husky": "9.1.7",
    "nanostores": "1.0.1",
    "pino": "9.14.0",
    "prom-client": "15.1.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "swr": "2.3.4"
  },
  "devDependencies": {
    "@hono/node-server": "1.19.13",
    "@types/node": "24.0.14",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "hono": "4.8.5",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "tsx": "4.20.3",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
