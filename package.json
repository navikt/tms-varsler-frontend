{
  "name": "tms-varsler-frontend",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "PUBLIC_APP_ENVIRONMENT=local astro dev",
    "start": "PUBLIC_APP_ENVIRONMENT=${PUBLIC_APP_ENVIRONMENT:-local} astro dev",
    "build": "PUBLIC_APP_ENVIRONMENT=${PUBLIC_APP_ENVIRONMENT:-local} astro check && PUBLIC_APP_ENVIRONMENT=${PUBLIC_APP_ENVIRONMENT:-local} astro build",
    "preview": "PUBLIC_APP_ENVIRONMENT=${PUBLIC_APP_ENVIRONMENT:-local} astro preview",
    "astro": "PUBLIC_APP_ENVIRONMENT=${PUBLIC_APP_ENVIRONMENT:-local} astro",
    "mock": "tsx --watch ./mock/server.ts",
    "test": "PUBLIC_APP_ENVIRONMENT=local vitest run",
    "test:watch": "PUBLIC_APP_ENVIRONMENT=local vitest",
    "test:coverage": "PUBLIC_APP_ENVIRONMENT=local vitest run --coverage",
    "test:e2e": "playwright test",
    "ts-check": "tsc --strict",
    "prettier": "prettier --write './src/**/*.{ts,tsx,astro}'",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/node": "9.3.0",
    "@astrojs/react": "4.3.0",
    "@nanostores/react": "1.1.0",
    "@navikt/aksel-icons": "8.10.5",
    "@navikt/ds-react": "8.10.4",
    "@navikt/nav-dekoratoren-moduler": "3.4.0",
    "@navikt/oasis": "3.8.0",
    "@opentelemetry/sdk-node": "0.218.0",
    "astro": "5.11.2",
    "dayjs": "1.11.20",
    "husky": "9.1.7",
    "nanostores": "1.3.0",
    "pino": "9.14.0",
    "prom-client": "15.1.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "swr": "2.4.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@hono/node-server": "1.16.0",
    "@playwright/test": "1.60.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.0.14",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitest/coverage-v8": "4.1.8",
    "hono": "4.12.25",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "tsx": "4.22.1",
    "typescript": "5.8.3",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
