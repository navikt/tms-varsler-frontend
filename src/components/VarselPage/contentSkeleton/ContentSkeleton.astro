---
import { Box, Heading, HStack, Skeleton, VStack } from "@navikt/ds-react";
import { type Locale } from "@src/customTypes/Locale";
import styles from "./ContentSkeleton.module.css";

const currentLocale = Astro.currentLocale as Locale;

import { text } from "@language/text";
---

<div aria-label={text.loadingMessage[currentLocale]} class={styles.skeleton}>
  <Heading as={Skeleton} size="large"> Oppgaver </Heading>
  <Box
    margin="space-4"
    padding="space-24"
    borderRadius="12"
    className="w-56"
  >
    <HStack gap="space-12">
      <Skeleton variant="circle" width={32} height={32} />
      <VStack width="90%" gap="space-4">
        <Skeleton variant="rectangle" width="90%" />
        <Skeleton variant="rectangle" width="120px" />
      </VStack>
    </HStack>
  </Box>
  <Box padding="space-24" borderRadius="12" className="w-56">
    <HStack gap="space-12">
      <Skeleton variant="circle" width={32} height={32} />
      <VStack width="90%" gap="space-4">
        <Skeleton variant="rectangle" width="90%" />
        <Skeleton variant="rectangle" width="120px" />
      </VStack>
    </HStack>
  </Box>
</div>
