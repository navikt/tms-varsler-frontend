---
import { fetchDecoratorHtml } from "@navikt/nav-dekoratoren-moduler/ssr";
import styles from "./Layout.module.css";
import { appBaseUrl } from "@utils/urls";
import { type DecoratorLocale } from "@navikt/nav-dekoratoren-moduler";
import { type Locale } from "@src/customTypes/Locale";
const currentLocale: Locale = Astro.currentLocale as Locale;
import "./global.css";

// Use the decorator's HTML output (not the React components): @astrojs/react 6
// drops <link rel="stylesheet"> / rel="preload" emitted by server-rendered
// React components, which left the decorator unstyled. set:html injects the
// markup verbatim. Matches the team pattern (tms-min-side, tms-utkast-frontend).
const Decorator = await fetchDecoratorHtml({
  env: "dev",
  params: {
    context: "privatperson",
    language: currentLocale as DecoratorLocale,
    availableLanguages: [
      {
        locale: "nb",
        url: `${appBaseUrl}/`,
        handleInApp: false,
      },
      {
        locale: "en",
        url: `${appBaseUrl}/en`,
        handleInApp: false,
      },
      {
        locale: "nn",
        url: `${appBaseUrl}/nn`,
        handleInApp: false,
      },
    ],
  },
});

const {
  DECORATOR_HEAD_ASSETS,
  DECORATOR_HEADER,
  DECORATOR_FOOTER,
  DECORATOR_SCRIPTS,
} = Decorator;
---

<!doctype html>
<html lang={currentLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Astro description" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="noindex" />
    <title>Varsler</title>
    <link
      rel="preload"
      href="https://cdn.nav.no/aksel/@navikt/ds-css/8.10.4/index.min.css"
      as="style"
    />
    <link
      rel="stylesheet"
      href="https://cdn.nav.no/aksel/@navikt/ds-css/8.10.4/index.min.css"
    />
    <Fragment set:html={DECORATOR_HEAD_ASSETS} />
  </head>
  <body>
    <Fragment set:html={DECORATOR_HEADER} />
    <main id="maincontent" class={styles.layout}>
      <slot />
    </main>
    <Fragment set:html={DECORATOR_FOOTER} />
    <Fragment set:html={DECORATOR_SCRIPTS} />
  </body>
</html>
